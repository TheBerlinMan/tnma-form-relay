{
  "name": "form-relay",
  "version": "0.0.1",
  "private": true,
  "description": "Internal form backend: receives form POSTs from client sites and delivers branded notification emails via Resend.",
  "type": "module",
  "scripts": {
    "start": "npm run build && vercel dev",
    "build": "esbuild emails/*.tsx --format=esm --jsx=automatic --outdir=emails",
    "typecheck": "tsc --noEmit",
    "email:preview": "email dev --dir emails"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@neondatabase/serverless": "^1.1.0",
    "@react-email/components": "^0.0.36",
    "hono": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "react-email": "^3.0.7",
    "typescript": "^5.7.3",
    "vercel": "^54.11.1"
  }
}
