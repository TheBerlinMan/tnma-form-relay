# ── Required ──────────────────────────────────────────────────────────────
# Disable Vercel's Node.js body-parsing helpers — they consume the request
# stream before Hono can read it. Must also be set in the Vercel project env.
NODEJS_HELPERS=0


# Resend API key (Dashboard → API Keys). Sending access is enough.
RESEND_API_KEY=re_xxxxxxxxxxxx

# The From identity. MUST use your verified sending subdomain.
# The visitor's address goes in Reply-To automatically — never here.
MAIL_FROM="Agency Forms <forms@mail.youragency.com>"

# ── Optional (Phase 3) ────────────────────────────────────────────────────
# Setting this activates server-side Turnstile verification.
# TURNSTILE_SECRET_KEY=0x_xxxxxxxxxxxx

# ── Phase 2: durability ───────────────────────────────────────────────────
# Neon Postgres connection string for the durable submission log. The Vercel
# Neon integration names this form_relay_DATABASE_URL — the code reads both.
# Without it the service still sends; submissions just aren't logged durably.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Where operational alerts (bounces, exhausted retries) get emailed.
# ALERT_EMAIL=you@youragency.com

# Shared secret protecting GET /cron/retry. When set in the Vercel project,
# Vercel Cron sends it automatically as "Authorization: Bearer <secret>".
# CRON_SECRET=generate-with: openssl rand -hex 16

# Signing secret for POST /webhooks/resend (Resend Dashboard → Webhooks).
# Unsigned events are accepted (with a log warning) until this is set.
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
